# ============================================================
# World Ticket Backend — Environment Variables Reference
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── Application ─────────────────────────────────────────────
APP_ENV=development                          # development | staging | production
APP_NAME="World Ticket API"
APP_VERSION=1.0.0
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Security ────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=change_me_to_a_random_64_char_hex_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60              # 1 hour
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Database (PostgreSQL) ────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/worldticket_db
# For Alembic sync migrations only:
SYNC_DATABASE_URL=postgresql://user:password@localhost:5432/worldticket_db

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Cloudinary ───────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_DEFAULT=100/minute              # general endpoints
RATE_LIMIT_AUTH=10/minute                  # auth endpoints (login, register)

# ── Pagination Defaults ──────────────────────────────────────
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
